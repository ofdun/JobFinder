@startuml
skinparam shadowing false
skinparam packageStyle rectangle
skinparam backgroundColor white
skinparam conditionStyle diamond

|Работодатель|
|Платформа|
|Соискатель|

|Работодатель|
start
:Авторизация в системе;
:Нажатие "Создать вакансию";
:Заполнение данных
(Название, ЗП, Навыки, Тип занятости);
:Публикация вакансии;

|Платформа|
:Валидация и сохранение вакансии;
:Публикация в общем списке;

|Соискатель|
:Вход на платформу;
:Настройка фильтров поиска;
:Изучение списка вакансий;
:Выбор вакансии;
:Нажатие кнопки "Откликнуться";

if (Авторизован?) then (Нет)
    :Регистрация / Авторизация;
else (Да)
endif

if (Есть резюме?) then (Нет)
    :Создание нового резюме;
else (Да)
endif

:Выбор резюме для отклика;
:Подтверждение отправки;

|Платформа|
:Создание записи "Отклик";

|Работодатель|
:Переход к списку откликов;
:Анализ резюме кандидата;

if (Кандидат интересен?) then (Нет)
    :Изменение статуса на "Отказ";
else (Да)
    :Изменение статуса на "Приглашение";
endif

|Платформа|
:Сохранение статуса;
stop

@enduml